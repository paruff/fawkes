# Example configuration for AWS S3 module (aws/s3)

# Required variables
bucket_name = "fawkes-dev-artifacts"

# Object lifecycle
# force_destroy    = false
# enable_versioning = false

# Encryption
# sse_algorithm = "AES256"  # AES256 | aws:kms
# kms_key_id    = null  # Required if sse_algorithm = aws:kms

# Public access block (all enabled by default)
# block_public_acls       = true
# block_public_policy     = true
# ignore_public_acls      = true
# restrict_public_buckets = true

# Access logging
# enable_logging = false

# Lifecycle rules
# lifecycle_rules = [
#   {
#     id      = "expire-old-versions"
#     enabled = true
#     noncurrent_version_expiration_days = 30
#   }
# ]
